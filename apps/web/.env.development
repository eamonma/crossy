# Vite dev-only defaults (never bundled into a build; see src/config/config.ts). No secrets:
# 1x00000000000000000000AA is Cloudflare's documented always-pass Turnstile test site key
# (https://developers.cloudflare.com/turnstile/troubleshooting/testing/), so the guest
# sign-in path is exercisable on the dev stack without provisioning a real Turnstile widget.
# A real deploy gets its values from /config.json at container start, never from this file.
VITE_GUESTS_ENABLED=true
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
