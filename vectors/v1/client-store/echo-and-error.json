  {
    "name": "§7/§11: a fatal error tears the connection down to reconnecting and preserves the overlay for post-reconnect re-send (INV-10)",
    "given": {
      "seq": 12,
      "sync": "live",
      "cols": 5,
      "rows": 4,
      "blocks": [2, 6, 13],
      "cells": { "0": { "v": "A", "by": "u1" } },
      "overlay": [{ "commandId": "c9", "cell": 1, "value": "B" }]
    },
    "when": [
      {
        "source": "server",
        "type": "error",
        "code": "INTERNAL",
        "fatal": true
