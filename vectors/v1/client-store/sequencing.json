      "seq": 12,
      "sync": "live",
      "cols": 5,
      "rows": 4,
      "blocks": [2, 6, 13],
      "cells": { "0": { "v": "A", "by": "u1" } },
      "overlay": []
    },
    "when": [
      {
        "source": "server",
        "type": "cellSet",
        "seq": 10,
        "cell": 1,
        "value": "B",
        "by": "u2",
        "commandId": "cx"
      }
    ],
    "then": {
      "seq": 12,
      "sync": "live",
      "overlay": [],
      "render": { "0": "A" },
