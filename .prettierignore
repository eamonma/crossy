pnpm-lock.yaml
DESIGN.md
PROTOCOL.md
reports/

# Swift build artifacts (apps/ios). Prettier has no Swift parser, so `prettier --check .`
# already skips *.swift in directory mode; this pins the generated .build/ tree (JSON and
# YAML manifests SwiftPM writes) out of formatting explicitly.
.build/

# Installed agent skills: vendored third-party content, not ours to format.
.agents/

# Sub-agent worktrees: separate checkouts living under the repo root; each lints and
# formats itself on its own branch.
.claude/

# Playwright run artifacts (e2e). Generated, not source.
e2e/test-results/
e2e/playwright-report/

# Apple's Universal Links association file. Its name is fixed and extensionless, so
# prettier can infer no parser; pin it out so `format:check` stays deterministic.
apps/web/public/.well-known/apple-app-site-association
