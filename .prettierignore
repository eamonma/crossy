pnpm-lock.yaml
DESIGN.md
PROTOCOL.md
reports/

# Swift build artifacts (apps/ios). Prettier has no Swift parser, so `prettier --check .`
# already skips *.swift in directory mode; this pins the generated .build/ tree (JSON and
# YAML manifests SwiftPM writes) out of formatting explicitly.
.build/

# Xcode-generated files (apps/ios/Crossy): asset-catalog JSON and the pbxproj are
# written by Xcode in its own style; reformatting them makes every Xcode save a diff.
*.xcassets/
*.xcodeproj/

# The extension's built output, mirrored into the iOS app as a committed derived cache
# (sync-safari-extension.sh) so the Xcode build stays node-free. It is dist/ under
# another name: never hand-edited, so never formatted.
apps/ios/Crossy/SafariResources/

# Untracked local reference bundle (never committed); ignored so local `format:check`
# matches what CI sees on a clean clone.
crossy-design-system (v2 reference)/

# Installed agent skills: vendored third-party content, not ours to format.
.agents/

# Sub-agent worktrees: separate checkouts living under the repo root; each lints and
# formats itself on its own branch.
.claude/

# Playwright run artifacts (e2e). Generated, not source.
e2e/test-results/
e2e/playwright-report/

# Apple's Universal Links association file. Its name is fixed and extensionless, so
# prettier can infer no parser; pin it out so `format:check` stays deterministic.
apps/web/public/.well-known/apple-app-site-association
